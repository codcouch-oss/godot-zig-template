# Zig build artifacts
.zig-cache/
zig-out/

# Godot editor cache (regenerated on open)
.godot/*
!.godot/extension_list.cfg
!.godot/editor/
.godot/editor/*
!.godot/editor/editor_layout.cfg

# Compiled extension binaries
binaries/

# Godot import metadata and resource UIDs (regenerated by the editor)
*.import
*.uid

# VSCode user-specific settings
.vscode/settings.json
.vscode/tasks.json

# Windows junk
Thumbs.db
Desktop.ini
